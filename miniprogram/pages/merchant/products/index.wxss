.product-container {
  padding: 24rpx;
  background-color: var(--background-color);
  min-height: 100vh;
}

/* 顶部操作栏 */
.header-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.search-bar {
  flex: 1;
  height: 72rpx;
  background: var(--card-bg);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.search-icon {
  margin-right: 12rpx;
  font-size: 24rpx;
}

.search-bar input {
  flex: 1;
  font-size: 26rpx;
}

.add-btn {
  margin: 0 !important;
  background: var(--primary-color) !important;
  color: var(--text-main) !important;
  font-size: 26rpx !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
  border-radius: 36rpx !important;
  padding: 0 30rpx !important;
  font-weight: bold !important;
}

/* 商品列表 */
.product-list {
  display: flex;
  flex-direction: column;
}

.product-card {
  display: flex;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.product-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background: #f8f8f8;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-main);
  flex: 1;
  margin-right: 12rpx;
}

.category-tag {
  font-size: 20rpx;
  color: var(--info-color);
  background: rgba(24, 144, 255, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.price-box {
  display: flex;
  align-items: baseline;
  color: var(--danger-color);
}

.unit {
  font-size: 24rpx;
  font-weight: bold;
}

.price {
  font-size: 36rpx;
  font-weight: bold;
}

.stock {
  font-size: 24rpx;
  color: var(--text-muted);
}

.action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f9f9f9;
}

.status-box {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.dot-approved { background: var(--success-color); }
.dot-pending { background: #faad14; }
.dot-rejected { background: var(--danger-color); }
.dot-off { background: var(--text-muted); }

.status-text {
  font-size: 22rpx;
  color: var(--text-sub);
}

.btn-group {
  display: flex;
  gap: 16rpx;
}

.btn-edit, .btn-del {
  margin: 0 !important;
  font-size: 22rpx !important;
  height: 48rpx !important;
  line-height: 48rpx !important;
  padding: 0 20rpx !important;
  border-radius: 24rpx !important;
}

.btn-edit {
  background: #f0f0f0 !important;
  color: var(--text-main) !important;
}

.btn-del {
  background: #fff1f0 !important;
  color: var(--danger-color) !important;
}

/* 缺省状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: var(--text-muted);
  font-size: 28rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  position: relative;
  border-bottom: 1rpx solid #f5f5f5;
}

.close-icon {
  position: absolute;
  right: 30rpx;
  top: 30rpx;
  font-size: 40rpx;
  color: #999;
  font-weight: normal;
}

.modal-body {
  padding: 30rpx;
  flex: 1;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.half { flex: 1; }

.label {
  display: block;
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 160rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.upload-box {
  width: 200rpx;
  height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}

.plus { font-size: 60rpx; margin-bottom: 10rpx; }
.tip { font-size: 22rpx; }

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-mask {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 48rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-footer {
  padding: 30rpx;
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.btn-cancel {
  flex: 1;
  background: #f5f5f5 !important;
  color: var(--text-sub) !important;
  font-size: 28rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-radius: 44rpx !important;
}

.btn-confirm {
  flex: 2;
  background: var(--primary-color) !important;
  color: var(--text-main) !important;
  font-size: 28rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-radius: 44rpx !important;
  font-weight: bold !important;
}
