.order-container {
  background-color: var(--background-color);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部 Tab */
.tab-header {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.tab-item {
  flex: 1;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-sub);
  position: relative;
}

.tab-item.active {
  color: var(--text-main);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 6rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
}

.badge {
  position: absolute;
  top: 15rpx;
  right: 20rpx;
  background: var(--danger-color);
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

/* 订单列表 */
.order-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.order-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.order-sn {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-main);
}

.order-status {
  font-size: 24rpx;
  font-weight: 500;
}

.status-paid { color: var(--primary-color); }
.status-accepted { color: var(--info-color); }
.status-ready { color: var(--success-color); }
.status-delivering { color: #faad14; }
.status-completed { color: var(--text-muted); }

/* 客户信息 */
.customer-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-main);
  display: block;
}

.order-time {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.customer-contact {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.phone {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-right: 12rpx;
}

.call-btn {
  font-size: 24rpx;
}

/* 订单内容 */
.order-content {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.goods-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.goods-item:last-child {
  margin-bottom: 0;
}

.goods-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-main);
}

.goods-count {
  font-size: 26rpx;
  color: var(--text-sub);
  margin: 0 30rpx;
}

.goods-price {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 500;
}

.order-remark {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #e0e0e0;
  display: flex;
}

.remark-label {
  font-size: 24rpx;
  color: var(--danger-color);
  white-space: nowrap;
}

.remark-content {
  font-size: 24rpx;
  color: var(--text-sub);
}

/* 底部操作 */
.order-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-info .label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-right: 8rpx;
}

.currency {
  font-size: 24rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.amount {
  font-size: 36rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.order-actions button {
  margin: 0 !important;
  font-size: 24rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  border-radius: 32rpx !important;
  padding: 0 24rpx !important;
}

.btn-primary {
  background: var(--primary-color) !important;
  color: var(--text-main) !important;
  font-weight: bold !important;
}

.btn-success {
  background: var(--success-color) !important;
  color: #fff !important;
  font-weight: bold !important;
}

.btn-detail {
  background: #f0f0f0 !important;
  color: var(--text-sub) !important;
}

/* 缺省页 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
