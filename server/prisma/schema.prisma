generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  openid    String   @unique
  nickname  String?
  avatar    String?
  phone     String?
  role      Role     @default(user)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  merchantApplications MerchantApplication[]
  riderApplications    RiderApplication[]
  merchants            Merchant[]
  riders               Rider[]
  orders               Order[]
  addresses            Address[]
  reviews              Review[]
}


enum Role {
  user
  merchant
  rider
  both
  admin
}

model MerchantApplication {
  id           Int      @id @default(autoincrement())
  userId       Int
  shopName     String
  licenseImg   String
  address      String
  contactPhone String
  status       AppStatus @default(pending)
  rejectReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model RiderApplication {
  id           Int      @id @default(autoincrement())
  userId       Int
  realName     String
  idCard       String
  idCardImg    String
  vehicleType  String
  status       AppStatus @default(pending)
  rejectReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

enum AppStatus {
  pending
  approved
  rejected
}

model Merchant {
  id          Int      @id @default(autoincrement())
  userId      Int
  shopName    String
  description String?
  logo        String?
  address     String
  lat         Float
  lng         Float
  isOpen      Boolean  @default(false)
  minOrder    Decimal  @db.Decimal(10, 2)
  deliveryFee Decimal  @default(0.00) @db.Decimal(10, 2)
  category    String?
  phone       String?
  licenseImg  String?
  rating      Float    @default(5.0)
  sales       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  products    Product[]
  orders      Order[]
  reviews     Review[]
}

model Rider {
  id           Int      @id @default(autoincrement())
  userId       Int
  realName     String
  isOnline     Boolean  @default(false)
  currentLat   Float?
  currentLng   Float?
  rating       Float    @default(5.0)
  totalOrders  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  orders       Order[]
}

model Product {
  id          Int           @id @default(autoincrement())
  merchantId  Int
  name        String
  price       Decimal       @db.Decimal(10, 2)
  imageUrl    String?
  description String?
  stock       Int           @default(0)
  sales       Int           @default(0)
  category    String?       @default("默认分类")
  status      ProductStatus @default(pending)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  merchant    Merchant      @relation(fields: [merchantId], references: [id])
  orderItems  OrderItem[]
}

enum ProductStatus {
  pending
  approved
  rejected
  off
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int
  merchantId    Int
  riderId       Int?
  totalAmount   Decimal     @db.Decimal(10, 2)
  deliveryFee   Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(pending_payment)
  address       String
  addressDetail String
  lat           Float?
  lng           Float?
  estimatedArrival DateTime? // 预估送达时间
  remark        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id])
  merchant      Merchant    @relation(fields: [merchantId], references: [id])
  rider         Rider?      @relation(fields: [riderId], references: [id])
  items         OrderItem[]
  payment       Payment?
  review        Review?
}

enum OrderStatus {
  pending_payment
  paid
  accepted
  preparing
  ready
  delivering
  delivered
  completed
  cancelled
  refund_pending
  refunded
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  productId   Int
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)

  order       Order    @relation(fields: [orderId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id              Int       @id @default(autoincrement())
  orderId         Int       @unique
  wxPrepayId      String?
  wxTransactionId String?
  amount          Decimal   @db.Decimal(10, 2)
  platformFee     Decimal   @db.Decimal(10, 2)
  status          String    @default("pending")
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  order           Order     @relation(fields: [orderId], references: [id])
}

model CommissionSetting {
  id            Int      @id @default(autoincrement())
  productRate   Float
  deliveryRate  Float
  deliveryRules Json
  updatedBy     String
  updatedAt     DateTime @updatedAt
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  phone     String
  address   String
  detail    String
  lat       Float
  lng       Float
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model Review {
  id         Int      @id @default(autoincrement())
  userId     Int
  merchantId Int
  orderId    Int      @unique
  rating     Float
  content    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
}