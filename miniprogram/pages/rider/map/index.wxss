.rider-map-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8;
}

.map-header {
  height: 88rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #e5e5e5;
  z-index: 10;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.back-icon {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 60rpx;
}

.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.delivery-map {
  flex: 1;
  width: 100%;
}

.map-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 50vh;
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  z-index: 5;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 20rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.order-list {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.task-item.active {
  background-color: rgba(7, 193, 96, 0.1);
  border: 2rpx solid #07C160;
}

.task-number {
  width: 56rpx;
  height: 56rpx;
  background-color: #07C160;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-item.active .task-number {
  background-color: #07C160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.3);
}

.task-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.task-address {
  display: flex;
  margin-bottom: 8rpx;
}

.task-label {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.task-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.task-meta {
  display: flex;
  gap: 20rpx;
}

.task-distance {
  font-size: 22rpx;
  color: #07C160;
  font-weight: 500;
}

.task-time {
  font-size: 22rpx;
  color: #ff9800;
  font-weight: 500;
}

.task-arrow {
  font-size: 28rpx;
  color: #999;
  margin-left: 16rpx;
}

.task-item.active .task-arrow {
  color: #07C160;
}

.panel-actions {
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-btn {
  width: 100% !important;
  margin: 0 !important;
  font-size: 28rpx !important;
  font-weight: bold !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  border-radius: 40rpx !important;
}

.action-btn.primary {
  background-color: #07C160 !important;
  color: #fff !important;
}