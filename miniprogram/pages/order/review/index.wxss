.container {
  padding: 30rpx;
  background: #f8f8f8;
  min-height: 100vh;
}
.review-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  color: #333;
}
.stars {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.star {
  font-size: 60rpx;
  filter: grayscale(100%);
  opacity: 0.3;
  transition: all 0.3s;
}
.star.active {
  filter: grayscale(0%);
  opacity: 1;
}
.rating-text {
  font-size: 32rpx;
  color: #ff9900;
  font-weight: bold;
  margin-bottom: 40rpx;
}
.review-input {
  width: 100%;
  height: 240rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 60rpx;
}
.submit-btn {
  width: 100%;
  border-radius: 40rpx;
  background: var(--primary-color);
  color: #333;
  font-weight: bold;
}