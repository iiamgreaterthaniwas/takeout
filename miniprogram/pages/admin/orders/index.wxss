.container {
  height: 100vh;
  background: #f5f5f5;
}
.list-container {
  padding: 20rpx;
  box-sizing: border-box;
}
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.order-header {
  display: flex;
  justify-content: space-between;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
}
.order-id {
  font-weight: bold;
  font-size: 28rpx;
}
.order-status {
  font-size: 26rpx;
  color: #ff8c00;
}
.order-status.completed { color: #3cc51f; }
.order-status.cancelled { color: #e64340; }
.order-info {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}
.label {
  color: #999;
}
.order-footer {
  margin-top: 20rpx;
  border-top: 1rpx dashed #eee;
  padding-top: 20rpx;
}
.time {
  font-size: 24rpx;
  color: #999;
}