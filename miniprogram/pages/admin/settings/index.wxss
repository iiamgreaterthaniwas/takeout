.container {
  height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}
.form-group {
  margin-bottom: 40rpx;
}
.label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}
.input {
  border: 1rpx solid #eee;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
}
.help-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
.submit-btn {
  margin-top: 60rpx;
  width: 100%;
}