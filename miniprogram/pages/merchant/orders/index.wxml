<view class="container order-container">
  <view class="tab-header">
    <view class="tab-item {{activeTab === 'paid' ? 'active' : ''}}" bindtap="switchTab" data-status="paid">
      <text>待接单</text>
      <view class="badge" wx:if="{{stats.pendingCount > 0}}">{{stats.pendingCount}}</view>
    </view>
    <view class="tab-item {{activeTab === 'accepted' ? 'active' : ''}}" bindtap="switchTab" data-status="accepted">
      <text>备餐中</text>
    </view>
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-status="all">
      <text>全部</text>
    </view>
  </view>

  <scroll-view scroll-y class="order-list" refresher-enabled="{{true}}" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <view class="empty-state" wx:if="{{orders.length === 0}}">
      <view class="empty-icon">📋</view>
      <text>暂时没有相关订单</text>
    </view>
    
    <view class="order-card card" wx:for="{{orders}}" wx:key="id">
      <view class="order-top">
        <view class="order-sn">#{{item.id}}</view>
        <view class="order-status status-{{item.status}}">{{statusMap[item.status]}}</view>
      </view>
      
      <view class="customer-info">
        <view class="customer-main">
          <text class="nickname">{{item.user.nickname || '匿名用户'}}</text>
          <text class="order-time">{{item.createdAt}}</text>
        </view>
        <view class="customer-contact" wx:if="{{item.contactPhone}}">
          <text class="phone">{{item.contactPhone}}</text>
          <view class="call-btn" bindtap="callCustomer" data-phone="{{item.contactPhone}}">📞</view>
        </view>
      </view>

      <view class="order-content">
        <view class="goods-list">
          <view class="goods-item" wx:for="{{item.items}}" wx:for-item="goods" wx:key="id">
            <text class="goods-name">{{goods.productName}}</text>
            <text class="goods-count">x{{goods.quantity}}</text>
            <text class="goods-price">￥{{goods.price}}</text>
          </view>
        </view>
        <view class="order-remark" wx:if="{{item.remark}}">
          <text class="remark-label">备注：</text>
          <text class="remark-content">{{item.remark}}</text>
        </view>
      </view>

      <view class="order-bottom">
        <view class="total-info">
          <text class="label">预计收入</text>
          <text class="currency">￥</text>
          <text class="amount">{{item.totalAmount}}</text>
        </view>
        <view class="order-actions">
          <button class="btn-primary" size="mini" wx:if="{{item.status === 'paid'}}" bindtap="handleAction" data-id="{{item.id}}" data-action="accept">确认接单</button>
          <button class="btn-success" size="mini" wx:if="{{item.status === 'accepted'}}" bindtap="handleAction" data-id="{{item.id}}" data-action="ready">制作完成</button>
          <button class="btn-detail" size="mini" bindtap="goToDetail" data-id="{{item.id}}">查看详情</button>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
