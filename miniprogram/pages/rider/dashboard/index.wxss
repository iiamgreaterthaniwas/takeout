.rider-container {
  padding-bottom: 40rpx;
}

.rider-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
}

.header-online {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
}

.header-offline {
  background: linear-gradient(135deg, #9E9E9E 0%, #757575 100%);
}

.status-content {
  flex: 1;
}

.status-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ffffff;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
  }
  70% {
    box-shadow: 0 0 0 12rpx rgba(255, 255, 255, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
  }
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stats-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
  padding: 0 30rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  position: relative;
}

.map-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.map-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.map-label {
  font-size: 20rpx;
  color: var(--info-color);
  font-weight: 500;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-main);
}

.refresh-btn {
  font-size: 24rpx;
  color: var(--info-color);
}

.order-list {
  padding: 0 30rpx;
}

.order-card {
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.shop-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.shop-icon {
  font-size: 28rpx;
}

.shop-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-main);
}

.order-status {
  font-size: 24rpx;
  color: var(--info-color);
  font-weight: 500;
}

.order-body {
  margin-bottom: 20rpx;
}

.addr-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot.pick {
  background-color: var(--info-color);
}

.dot.deliver {
  background-color: var(--danger-color);
}

.addr-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.customer {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 500;
}

.distance {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.time {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.btn-group-rider {
  display: flex;
  gap: 16rpx;
}

.nav-btn-rider {
  margin: 0 !important;
  background-color: var(--info-color) !important;
  color: #fff !important;
  font-size: 24rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  padding: 0 24rpx !important;
  border-radius: 32rpx !important;
}

.deliver-btn {
  margin: 0 !important;
  background-color: var(--success-color) !important;
  color: #fff !important;
  font-size: 26rpx !important;
  font-weight: bold !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  padding: 0 40rpx !important;
  border-radius: 32rpx !important;
}

.accept-btn {
  margin: 0 !important;
  background-color: var(--danger-color) !important;
  color: #fff !important;
  font-size: 26rpx !important;
  font-weight: bold !important;
  height: 70rpx !important;
  line-height: 70rpx !important;
  padding: 0 48rpx !important;
  border-radius: 35rpx !important;
}

.order-fee {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--danger-color);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--text-hint);
}
