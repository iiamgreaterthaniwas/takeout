.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}
.form-group {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}
.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}
.form-item.align-top {
  align-items: flex-start;
}
.form-item.border-none {
  border-bottom: none;
}
.form-item:last-child {
  border-bottom: none;
}
.label {
  width: 180rpx;
  font-size: 28rpx;
  color: #333;
}
.input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
}
.textarea {
  flex: 1;
  height: 120rpx;
  font-size: 28rpx;
  text-align: left;
}
.address-picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.address-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.address-text.placeholder {
  color: #999;
}
.picker-box {
  flex: 1;
}
.picker-content {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.picker-text {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}
.picker-text.placeholder {
  color: #999;
}
.arrow {
  margin-left: 10rpx;
  color: #ccc;
  font-size: 28rpx;
}
.upload-area {
  width: 200rpx;
  height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}
.preview-img {
  width: 100%;
  height: 100%;
}
.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}
.upload-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}
.upload-text {
  font-size: 24rpx;
}

.footer-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx;
  background: #fff;
  box-sizing: border-box;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}
.submit-btn {
  width: 100%;
  border-radius: 40rpx;
}