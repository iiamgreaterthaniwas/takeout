# 数据库连接
DATABASE_URL="mysql://user:password@localhost:3306/takeout_db"

# Redis 连接
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 配置
JWT_SECRET=your_jwt_secret_key

# 微信支付配置 (如果有)
WX_APP_ID=your_app_id
WX_MCH_ID=your_mch_id
WX_API_V3_KEY=your_api_v3_key
WX_PRIVATE_KEY_PATH=certs/apiclient_key.pem

# 服务器端口
PORT=3000
