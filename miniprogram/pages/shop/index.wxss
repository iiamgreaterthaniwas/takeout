page {
  height: 100vh;
  overflow: hidden;
}

.shop-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--card-bg);
}

/* 头部样式 */
.shop-header {
  position: relative;
  height: 240rpx;
  flex-shrink: 0;
}
.shop-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--card-bg) 100%);
  opacity: 0.6;
  z-index: 1;
}
.shop-header-content {
  position: relative;
  z-index: 2;
  display: flex;
  padding: 40rpx 30rpx 0 30rpx;
}
.shop-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  background: var(--card-bg);
}
.shop-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.shop-name {
  font-size: 38rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 8rpx;
}
.shop-desc {
  font-size: 22rpx;
  color: var(--text-sub);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.shop-meta {
  font-size: 22rpx;
  color: var(--text-sub);
}

/* Tabs 切换 */
.tabs {
  display: flex;
  height: 80rpx;
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--border-color);
}
.tab {
  flex: 1;
  text-align: center;
  line-height: 80rpx;
  font-size: 30rpx;
  color: var(--text-sub);
  position: relative;
}
.tab.active {
  color: var(--text-main);
  font-weight: bold;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--primary-color);
  border-radius: 4rpx;
}

.tab-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 搜索框 */
.search-box {
  padding: 20rpx 30rpx;
  background: var(--background-color);
  display: flex;
  align-items: center;
}
.search-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
  color: var(--text-muted);
}
.search-input {
  flex: 1;
  height: 60rpx;
  background: var(--card-bg);
  border-radius: 30rpx;
  padding: 0 30rpx;
  font-size: 26rpx;
  color: var(--text-main);
}

/* 菜单区域双栏布局 */
.menu-container {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类栏 */
.menu-left {
  width: 160rpx;
  background: var(--background-color);
  height: 100%;
}
.menu-cat {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-sub);
  transition: all 0.3s;
}
.menu-cat.active {
  background: var(--card-bg);
  color: var(--text-main);
  font-weight: bold;
}

/* 右侧商品列表 */
.menu-right {
  flex: 1;
  background: var(--card-bg);
  height: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.category-title {
  font-size: 26rpx;
  color: var(--text-sub);
  padding: 24rpx 0;
  font-weight: bold;
}
.product-item {
  display: flex;
  margin-bottom: 40rpx;
}
.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: var(--background-color);
  margin-right: 20rpx;
  flex-shrink: 0;
}
.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 6rpx;
}
.product-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.product-sales {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}
.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}
.price-box {
  display: flex;
  align-items: baseline;
}
.price-symbol {
  font-size: 24rpx;
  color: var(--danger-color);
  font-weight: bold;
}
.price-value {
  font-size: 36rpx;
  color: var(--danger-color);
  font-weight: bold;
}



/* 底部购物车 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: #333;
  display: flex;
  align-items: center;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}
.cart-icon-wrap {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  background: #555;
  border-radius: 50%;
  border: 8rpx solid #333;
  margin-left: 30rpx;
  margin-top: -40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.cart-icon-wrap.has-items {
  background: var(--primary-color);
}
.cart-icon {
  font-size: 48rpx;
}
.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #ff4a00;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  font-weight: bold;
}
.cart-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.cart-price {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}
.cart-price .symbol {
  font-size: 24rpx;
}
.cart-empty {
  font-size: 28rpx;
  color: #999;
}
.cart-delivery {
  font-size: 20rpx;
  color: #999;
}
.cart-actions {
  display: flex;
  height: 100%;
}
.add-cart-btn {
  width: 180rpx;
  height: 100%;
  line-height: 100rpx;
  text-align: center;
  background: #555;
  color: #999;
  font-size: 28rpx;
  font-weight: bold;
}
.add-cart-btn.active {
  background: #ff8c00;
  color: #fff;
}
.cart-btn {
  width: 220rpx;
  height: 100%;
  line-height: 100rpx;
  text-align: center;
  background: #555;
  color: #999;
  font-size: 30rpx;
  font-weight: bold;
}
.cart-btn.active {
  background: var(--primary-color);
  color: #333;
}

/* 购物车详情弹窗 */
.cart-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}
.cart-detail {
  position: fixed;
  bottom: 100rpx; /* 在 cart-bar 上方 */
  left: 0;
  width: 100%;
  background: #fff;
  z-index: 1001;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}
.cart-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #f8f8f8;
  border-radius: 24rpx 24rpx 0 0;
}
.cart-detail-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}
.cart-detail-clear {
  font-size: 24rpx;
  color: #666;
  display: flex;
  align-items: center;
}
.cart-detail-list {
  max-height: 60vh;
  padding: 0 30rpx;
  box-sizing: border-box;
}
.cart-detail-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}
.cart-detail-item:last-child {
  border-bottom: none;
}
.cart-detail-item .item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.cart-detail-item .item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.cart-detail-item .item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.cart-detail-item .item-desc {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cart-detail-item .item-price {
  font-size: 32rpx;
  color: #ff4a00;
  font-weight: bold;
}

/* 评价和商家信息样式 */
.review-list {
  flex: 1;
  background: #f8f8f8;
  padding: 20rpx;
}
.empty {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
}
.review-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.rating {
  font-size: 26rpx;
  color: #ff9900;
  font-weight: bold;
}
.review-content {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.5;
}
.review-order-items {
  font-size: 24rpx;
  color: #666;
  background: #f8f8f8;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
}

.merchant-detail {
  flex: 1;
  background: #f8f8f8;
  padding: 20rpx;
}
.merchant-info-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}
.merchant-info-item .icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}
.merchant-info-item .text {
  flex: 1;
}
.merchant-info-item .title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: bold;
}
.merchant-info-item .desc {
  font-size: 26rpx;
  color: #666;
}
.merchant-info-item .arrow {
  color: #ccc;
  font-size: 30rpx;
}
.merchant-license {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
}
.merchant-license .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}
.license-img {
  width: 100%;
  border-radius: 8rpx;
}