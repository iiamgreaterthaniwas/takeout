.apply-container {
  padding: 30rpx;
  background-color: var(--background-color);
}

.form-group {
  display: flex;
  flex-direction: column;
}

.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
}

.form-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.input {
  height: 80rpx;
  font-size: 28rpx;
  padding: 0 10rpx;
}

.upload-group {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
}

.upload-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.upload-box {
  width: 100%;
  height: 360rpx;
  background-color: #f9f9f9;
  border: 2rpx dashed #dcdfe6;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}

.add-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.submit-btn {
  margin-top: 60rpx;
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  background-color: var(--primary-color);
  font-size: 32rpx;
}
