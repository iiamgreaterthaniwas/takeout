.login-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 120rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-muted);
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background-color: var(--primary-color) !important;
  color: #333 !important;
  font-size: 32rpx;
  border: none;
}

.login-form {
  width: 100%;
  margin-top: 40rpx;
}
.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  margin-bottom: 40rpx;
}
.avatar-item {
  flex-direction: column;
  border-bottom: none;
}
.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  border-radius: 50%;
  margin-bottom: 20rpx;
  background: #f5f5f5;
  overflow: hidden;
}
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.hint {
  font-size: 24rpx;
  color: #999;
}
.nickname-item {
  background: #f9f9f9;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
}
.label {
  width: 100rpx;
  font-size: 30rpx;
  color: #333;
}
.nickname-input {
  flex: 1;
  font-size: 30rpx;
}
