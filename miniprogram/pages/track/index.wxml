<view class="container track-container">
  <map 
    id="trackMap"
    class="map"
    latitude="{{latitude}}" 
    longitude="{{longitude}}" 
    scale="16"
    circles="{{circles}}"
    show-location
  ></map>
  
  <view class="track-info card">
    <view class="status-title">骑手正在为您配送</view>
    <view class="rider-info">
      <view class="rider-avatar">🛵</view>
      <view class="rider-detail">
        <text class="rider-name">骑手：{{riderName || '正在获取'}}</text>
        <text class="rider-distance">距离您 {{distance || '--'}} 米</text>
      </view>
    </view>
  </view>
</view>
