<view class="container" wx:if="{{order}}">
  <!-- 状态栏 -->
  <view class="status-section card">
    <view class="status-title">{{order.statusText}}</view>
    <view class="status-desc" wx:if="{{order.status === 'delivering'}}">订单正在配送中，请耐心等待</view>
    <view class="status-desc" wx:else>感谢您的信任，祝您生活愉快</view>
    <view class="status-actions" wx:if="{{order.status === 'delivering'}}">
      <button class="action-btn" size="mini" type="primary" bindtap="goToTrack">查看轨迹</button>
    </view>
    <view class="status-actions" wx:if="{{order.status === 'pending_payment'}}">
      <button class="action-btn" size="mini" bindtap="cancelOrder">取消订单</button>
      <button class="action-btn" size="mini" type="primary" bindtap="payOrder">去支付</button>
    </view>
    <view class="status-actions" wx:if="{{order.status === 'completed' || order.status === 'cancelled' || order.status === 'refunded'}}">
      <button class="action-btn" size="mini" type="primary" wx:if="{{order.status === 'completed' && !order.review}}" bindtap="goToReview">去评价</button>
      <button class="action-btn" size="mini" type="warn" bindtap="deleteOrder">删除订单</button>
    </view>
  </view>

  <!-- 店铺信息 -->
  <view class="merchant-section card">
    <view class="merchant-header">
      <image class="merchant-logo" src="{{order.merchant.logo || '/images/default-shop.png'}}" mode="aspectFill"></image>
      <text class="merchant-name">{{order.merchant.shopName}}</text>
      <view class="contact-btn" bindtap="callMerchant">
        <text class="icon">📞</text>
      </view>
    </view>
    
    <view class="goods-list">
      <view class="goods-item" wx:for="{{order.items}}" wx:key="id">
        <image class="goods-img" src="{{item.displayImageUrl}}" mode="aspectFill"></image>
        <view class="goods-info">
          <text class="goods-name">{{item.displayProductName}}</text>
          <text class="goods-count">x{{item.quantity}}</text>
        </view>
        <text class="goods-price">￥{{item.formattedPrice}}</text>
      </view>
    </view>

    <view class="fee-section">
      <view class="fee-item">
        <text>包装费</text>
        <text>￥0.00</text>
      </view>
      <view class="fee-item">
        <text>配送费</text>
        <text>￥{{order.formattedDeliveryFee}}</text>
      </view>
    </view>

    <view class="total-section">
      <text class="total-label">合计</text>
      <text class="total-price">￥{{order.formattedAmount}}</text>
    </view>
  </view>

  <!-- 配送信息 -->
  <view class="delivery-section card">
    <view class="section-title">配送信息</view>
    <view class="info-item">
      <text class="info-label">收货地址</text>
      <text class="info-content">{{order.address}} {{order.addressDetail}}</text>
    </view>
    <view class="info-item" wx:if="{{order.rider}}">
      <text class="info-label">配送骑手</text>
      <text class="info-content">{{order.rider.realName}} ({{order.rider.phone || '暂无电话'}})</text>
    </view>
    <view class="info-item" wx:if="{{order.distanceDisplay}}">
      <text class="info-label">骑手距离</text>
      <text class="info-content highlight">{{order.distanceDisplay}}</text>
    </view>
    <view class="info-item" wx:if="{{order.status === 'delivering' && order.formattedEta}}">
      <text class="info-label">预计送达</text>
      <text class="info-content eta">{{order.formattedEta}}</text>
    </view>
    <view class="nav-section" wx:if="{{order.rider && order.status === 'delivering' && order.rider.currentLat}}">
      <button class="nav-btn" bindtap="openNavigation">
        <text class="nav-icon">🧭</text> 查看导航
      </button>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="order-info-section card">
    <view class="section-title">订单信息</view>
    <view class="info-item">
      <text class="info-label">订单编号</text>
      <text class="info-content">{{order.id}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">下单时间</text>
      <text class="info-content">{{order.createdAt}}</text>
    </view>
    <view class="info-item" wx:if="{{order.remark}}">
      <text class="info-label">订单备注</text>
      <text class="info-content">{{order.remark}}</text>
    </view>
  </view>
</view>
