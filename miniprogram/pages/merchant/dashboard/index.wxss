.merchant-container {
  padding: 24rpx;
  background-color: var(--background-color);
  min-height: 100vh;
}

/* 头部样式 */
.merchant-header {
  display: flex;
  padding: 30rpx;
  align-items: center;
  margin-bottom: 30rpx;
}

.shop-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background-color: #f0f0f0;
}

.shop-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.shop-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.shop-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-main);
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.tag-open {
  background-color: rgba(0, 181, 120, 0.1);
  color: var(--success-color);
}

.tag-closed {
  background-color: rgba(153, 153, 153, 0.1);
  color: var(--text-muted);
}

.shop-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.shop-id {
  font-size: 24rpx;
  color: var(--text-muted);
}

.switch-wrap {
  display: flex;
  align-items: center;
}

.switch-label {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-right: 12rpx;
}

/* 标题样式 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-main);
  margin: 30rpx 0 20rpx 6rpx;
}

/* 统计卡片 */
.stats-grid {
  display: flex;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.income-bg { background-color: rgba(255, 204, 0, 0.1); }
.order-bg { background-color: rgba(24, 144, 255, 0.1); }

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.stat-num {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-main);
}

/* 功能网格 */
.function-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.func-item {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  align-items: flex-start;
}

.func-icon {
  font-size: 48rpx;
  margin-bottom: 20rpx;
}

.func-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.func-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}
