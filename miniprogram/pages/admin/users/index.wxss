.container {
  height: 100vh;
  background: #f5f5f5;
}
.list-container {
  padding: 20rpx;
  box-sizing: border-box;
}
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.user-header {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  background: #ccc;
}
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.nickname {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}
.role-tag {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
.status-tag {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.status-tag.active {
  color: #3cc51f;
  background: #eef9ee;
}
.status-tag.banned {
  color: #e64340;
  background: #fcebeb;
}
.user-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
.time {
  font-size: 24rpx;
  color: #999;
}