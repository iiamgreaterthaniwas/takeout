.home-container {
  padding: 0 0 120rpx 0;
  background-color: var(--background-color);
  min-height: 100vh;
}

/* 顶部搜索栏 */
.header-bar {
  background: var(--primary-color);
  padding: 30rpx 30rpx 40rpx 30rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}
.location {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-main);
}
.location .icon {
  margin-right: 8rpx;
}
.location .arrow {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: var(--text-sub);
}
.search-box {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  height: 70rpx;
  border-radius: 35rpx;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.search-icon {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-right: 12rpx;
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-main);
}

/* 金刚区（分类导航） */
.category-grid {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background: var(--card-bg);
  margin: -20rpx 30rpx 30rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}
.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.cat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}
.bg-orange { background: #FFF4E5; }
.bg-blue { background: #E5F3FF; }
.bg-yellow { background: #FFF9E5; }
.bg-pink { background: #FFE5F0; }
.bg-green { background: #E5F9E5; }
.cat-text {
  font-size: 24rpx;
  color: var(--text-main);
}

/* 附近商家 */
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  padding: 0 30rpx 20rpx 30rpx;
  color: var(--text-main);
}
.shop-list {
  padding: 0 6rpx; /* 配合 card 的 margin */
  box-sizing: border-box;
}
.shop-card {
  display: flex;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 0 24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.shop-logo-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.shop-logo {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: var(--background-color);
}
.closed-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}
.shop-closed {
  opacity: 0.7;
}
.shop-closed .shop-name {
  color: var(--text-muted);
}
.shop-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}
.shop-name-row {
  display: flex;
  align-items: center;
}
.shop-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.shop-stats {
  font-size: 22rpx;
  color: var(--text-sub);
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}
.rating {
  color: #FF9500;
  font-weight: bold;
  margin-right: 16rpx;
}
.sales {
  margin-right: auto;
}
.shop-delivery {
  font-size: 22rpx;
  color: var(--text-sub);
  margin-top: 8rpx;
}
.divider {
  margin: 0 10rpx;
  color: var(--border-color);
}
.shop-tags {
  display: flex;
  margin-top: 12rpx;
}
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  background: var(--primary-color-light);
  color: #8B6E00;
  opacity: 0.8;
}
.tag.outline {
  background: transparent;
  border: 1rpx solid var(--primary-color);
  color: var(--primary-color-dark);
}

/* 悬浮购物车 */
.floating-cart {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx; /* 防止被 tabBar 遮挡 */
  width: 100rpx;
  height: 100rpx;
  background: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(255, 204, 0, 0.4);
  z-index: 100;
}
.floating-cart .cart-icon {
  font-size: 50rpx;
}
.floating-cart .cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: var(--danger-color);
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 6rpx;
  box-sizing: border-box;
}