.confirm-container {
  padding: 24rpx;
  background-color: var(--background-color);
  padding-bottom: 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.address-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.address-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.addr-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.addr-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.addr-detail {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.addr-sub {
  font-size: 24rpx;
  color: var(--text-muted);
}

.addr-contact {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-sub);
}

.default-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 152, 0, 0.12);
  color: #ff9800;
  font-size: 20rpx;
}

.addr-empty {
  flex: 1;
  font-size: 32rpx;
  color: var(--primary-color-dark);
  font-weight: 500;
}

.arrow {
  color: var(--text-muted);
  font-size: 24rpx;
}

.contact-card {
  padding: 10rpx 30rpx;
}

.input-group {
  display: flex;
  align-items: center;
  height: 90rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.input-group:last-child {
  border-bottom: none;
}

.input-label {
  width: 140rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
}

.order-card {
  margin-top: 24rpx;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.shop-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-main);
  border-bottom: 1rpx solid var(--border-color);
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
}

.goods-list {
  display: flex;
  flex-direction: column;
}

.goods-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.goods-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background: var(--background-color);
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.goods-name {
  font-size: 28rpx;
  color: var(--text-main);
}

.goods-qty {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.goods-price {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-main);
}

.fee-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--text-sub);
  margin-top: 20rpx;
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30rpx;
  border-top: 1rpx dashed var(--border-color);
  padding-top: 30rpx;
}

.total-label {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: bold;
}

.total-price {
  font-size: 36rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.remark-card {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.label {
  font-size: 28rpx;
  width: 140rpx;
  font-weight: bold;
  color: var(--text-main);
}

.remark-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: var(--card-bg);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-right: 8rpx;
}

.final-price {
  font-size: 40rpx;
  color: var(--danger-color);
  font-weight: bold;
}

.pay-btn {
  margin: 0 !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  border-radius: 40rpx !important;
  width: 240rpx !important;
  background: var(--primary-color) !important;
  color: var(--text-main) !important;
  font-weight: bold !important;
}
