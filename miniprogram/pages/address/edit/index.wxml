<view class="container address-edit-page">
  <view class="form-card">
    <view class="form-item">
      <text class="label">联系人</text>
      <input class="input" placeholder="请输入联系人" value="{{form.name}}" data-field="name" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
    </view>

    <view class="form-item picker" bindtap="chooseLocation">
      <text class="label">收货地址</text>
      <text class="picker-text {{form.address ? '' : 'placeholder'}}">{{form.address || '请选择地址'}}</text>
    </view>

    <view class="form-item">
      <text class="label">详细地址</text>
      <input class="input" placeholder="楼栋、门牌号等" value="{{form.detail}}" data-field="detail" bindinput="onInput" />
    </view>

    <view class="form-item switch-item">
      <text class="label">设为默认</text>
      <switch checked="{{form.isDefault}}" bindchange="onDefaultChange" color="#07c160" />
    </view>
  </view>

  <button class="submit-btn" bindtap="submit">保存地址</button>
</view>
