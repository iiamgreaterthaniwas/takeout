.container {
  padding: 24rpx;
  background-color: var(--background-color);
  min-height: 100vh;
  box-sizing: border-box;
}

.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-top: 200rpx;
  color: var(--text-muted);
}

.order-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.order-main {
  display: flex;
}

.shop-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: var(--background-color);
}

.order-info {
  flex: 1;
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
}

.shop-name {
  font-weight: bold;
  font-size: 30rpx;
  color: var(--text-main);
}

.status {
  color: #FF9500;
  font-size: 26rpx;
}

.order-content {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  color: var(--text-sub);
  font-size: 26rpx;
}

.goods {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 20rpx;
}

.price {
  font-weight: bold;
  color: var(--text-main);
}

.order-footer {
  text-align: right;
  border-top: 1rpx solid var(--border-color);
  padding-top: 24rpx;
}

.action-btn {
  margin-left: 20rpx;
  display: inline-block;
}

.action-btn button {
  height: 60rpx !important;
  line-height: 60rpx !important;
  font-size: 26rpx !important;
  padding: 0 30rpx !important;
  border-radius: 30rpx !important;
  margin: 0 !important;
}
