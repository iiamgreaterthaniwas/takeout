<view class="container admin-container">
  <view class="header card bg-dark">
    <view class="admin-info">
      <text class="admin-name">管理员控制台</text>
    </view>
    <text class="admin-status">数据实时更新中</text>
  </view>

  <view class="stats-grid">
    <view class="stat-card card bg-blue">
      <text class="stat-num">{{stats.todayOrders || 0}}</text>
      <text class="stat-label">今日订单</text>
    </view>
    <view class="stat-card card bg-green">
      <text class="stat-num">￥{{stats.todayGMV || '0.00'}}</text>
      <text class="stat-label">今日交易额</text>
    </view>
    <view class="stat-card card bg-orange">
      <text class="stat-num">{{stats.newMerchants || 0}}</text>
      <text class="stat-label">新增商户</text>
    </view>
    <view class="stat-card card bg-purple">
      <text class="stat-num">{{stats.newRiders || 0}}</text>
      <text class="stat-label">新增骑手</text>
    </view>
  </view>

  <view class="menu-list card">
    <view class="menu-item" bindtap="goTo" data-page="review">
      <text>审核中心</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goTo" data-page="users">
      <text>用户管理</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goTo" data-page="orders">
      <text>平台订单</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goTo" data-page="settings">
      <text>平台抽成设置</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="chart-card card">
    <view class="chart-title">平台角色分布</view>
    <view class="role-list">
      <view class="role-item" wx:for="{{pieChart}}" wx:key="name">
        <text class="role-name">{{item.name}}</text>
        <text class="role-value">{{item.value}} 人</text>
      </view>
    </view>
  </view>
</view>